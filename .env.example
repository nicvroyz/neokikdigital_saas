# Neokik Digital SaaS - Root Environment Variables (for Docker Compose Setup)

# Database
DB_USER=neokik_admin
DB_PASSWORD=StrongPassword123!
DB_NAME=neokik_saas

# Security
JWT_SECRET=neokik_super_secret_jwt_key_2026

# Execution Mode
# Set to false in production to execute real docker commands, Mailcow requests, Caddy configs, and database operations.
MIGRATION_DRY_RUN=true

# Database Container (used by DatabaseService in production to execute commands)
MYSQL_CONTAINER_NAME=neokik-mysql

# Mailcow API Integration requirement (set to false to warn but not fail site migrations if Mailcow is down)
MAILCOW_REQUIRED=false
