# Configuración
jacvroyz.cl {
        request_body {
                max_size 10GB
        }

        reverse_proxy /api/* backend:5000
        reverse_proxy frontend:80
}

www.jacvroyz.cl {
	redir https://jacvroyz.cl{uri}
}

api.jacvroyz.cl {
	reverse_proxy backend:5000
}

mail.jacvroyz.cl {
	reverse_proxy https://nginx-mailcow:8443 {
		transport http {
			tls_insecure_skip_verify
		}
	}
}
papelesconcepcion.cl {
        request_body {
                max_size 10GB
        }

        root * /srv/neokik/sites/papelesconcepcion.cl/public_html

        php_fastcgi papelesconcepcion_cl:9000 {
                root /var/www/html
        }

        file_server
}

www.papelesconcepcion.cl {
        redir https://papelesconcepcion.cl{uri}
}
