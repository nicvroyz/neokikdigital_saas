[Unit]
Description=Neokik Digital SaaS Backend API Service
After=network.target postgresql.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/neokikdigital_saas/backend
ExecStart=/usr/bin/node /opt/neokikdigital_saas/backend/dist/server.js
Restart=always
RestartSec=10
Environment=NODE_ENV=production PORT=5000

[Install]
WantedBy=multi-user.target
